# OS
.DS_Store

tmp/**

# Claude runtime / transient state
claude/backups/
claude/cache/
claude/debug/
claude/file-history/
claude/history.jsonl
claude/mcp-needs-auth-cache.json
claude/plans/
claude/plugins/
claude/projects/
claude/sessions/
claude/session-env/
claude/shell-snapshots/
claude/tasks/
claude/ide/
claude/.mcp.json

# Agent nested installs (prevent accidents in subdirs)
**/.agent/
**/.trunk/

# ── .agents: track skills, ignore the rest ──
.agents/*
!.agents/skills/

# ── cursor: its own git repo — ignore entirely ──
cursor/

# ── .claude: track commands, skills, rules, settings — ignore transient data ──
.claude/*
!.claude/commands/
!.claude/skills/
!.claude/rules/
!.claude/settings.json
!.claude/settings.local.json
!.claude/CLAUDE.md

# Secrets safety net
*.env
.env*

# Node / Python
node_modules/
__pycache__/
*.pyc

# Other
claude/telemetry/**
